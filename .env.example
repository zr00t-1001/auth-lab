# JWT
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# Database (fallbacks exist in database.config.ts)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=1234
DB_NAME=auth_sys

# Development only: localhost (::1 / 127.0.0.1) cannot be GeoIP-resolved.
# The backend maps local browser logins to this public demo IP so sessions
# receive country/city/lat/lon during local lab testing.
LOCAL_DEV_GEO_IP=8.8.8.8
